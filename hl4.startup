# =====================================================
# Host Hl4 - LAN LL (192.168.0.0/24)
# =====================================================
# Activar interfaz LAN
ip link set eth1 up

# Pedir IP al servidor DHCP (RL)
dhclient eth1

# Gateway
ip route add default via 192.168.0.254

# Para que funcione el nameserver
cd shared
cp resolv.conf /etc/

