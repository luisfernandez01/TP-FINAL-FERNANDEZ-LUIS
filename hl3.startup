
# =====================================================
# Host Hl3 - LAN LL (192.162.0.0/20)
# =====================================================

# Activar interfaz LAN
ip link set eth1 up

# Pedir IP al servidor DHCP (RL)
dhclient eth1

# DNS (lo pide la consigna)
echo "nameserver 8.8.8.8" > /etc/resolv.conf

sleep infinity
