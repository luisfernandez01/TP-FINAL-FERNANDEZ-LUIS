$TTL 86400
@   IN  SOA ha1.empresa.izo. admin.empresa.izo. (
       2026031502 ; Serial
       3600       ; Refresh
       1800       ; Retry
       604800     ; Expire
       86400 )    ; Minimum TTL

; Nameserver de la zona
@   IN  NS  ha1.empresa.izo.

; -------------------------------------------------
; PTR de hosts en redes 10.x.x.x
; formato: ultimo_octeto.red.subred
; -------------------------------------------------

