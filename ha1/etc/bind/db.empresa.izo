hk1     IN  A       192.168.3.1       ; GW: 192.168.3.14 / RK / ETH1
hl1     IN  A       192.168.0.1       ; GW: 192.168.0.254 / RL / ETH1
hl2     IN  A       192.168.0.2       ; GW: 192.168.0.254 / RL / ETH1
hl3     IN  A       192.168.0.3       ; GW: 192.168.0.254 / RL / ETH1
hl4     IN  A       192.168.0.4       ; GW: 192.168.0.254 / RL / ETH1
hl5     IN  A       192.168.0.5       ; GW: 192.168.0.254 / RL / ETH1


