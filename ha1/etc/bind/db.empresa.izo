$TTL 86400
@   IN  SOA ha1.empresa.izo. admin.empresa.izo. (
        2026032301 ; Serial (incrementar cada cambio)
        604800  ; Refresh
        86400   ; Retry
        2419200 ; Expire
        604800) ; Minimum

; -------------------------
; Nameserver
; -------------------------
@       IN  NS      ha1.empresa.izo.
ha1     IN  A       192.168.10.1      ; Host principal HA1


; -------------------------
; Hosts (IP asignable, gateway, router/interface)
; -------------------------
; -------------------------
; Hosts
; -------------------------
hb1     IN  A       10.0.0.1          ; GW: 10.0.255.254 / RB / ETH3
hc1     IN  A       172.16.0.1        ; GW: 172.16.1.254 / RC / ETH3
hz1     IN  A       10.10.10.1        ; GW: 10.10.10.6 / RZY / ETH3
hy1     IN  A       10.10.8.1         ; GW: 10.10.3.254 / RZY / ETH2
