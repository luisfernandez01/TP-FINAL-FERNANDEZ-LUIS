# =====================================================
# Host Hl1 - LAN LL (192.168.0.1/24)
# =====================================================

# IP y conexión
ip addr add 192.168.0.1/24 dev eth1
ip link set eth1 up

# Gateway
ip route add default via 192.168.0.254

# Para que funcione el nameserver
cd shared
cp resolv.conf /etc/

