# Host LE
# Conectado a RE - LAN 172.31.0.0/18
# =====================================================
# IP y conexió
ip addr add 172.31.0.1/18 dev eth2
ip link set eth2 up
# Gateway
ip route add default via 172.31.63.254

# Para que funcione el nameserver
cd shared
cp resolv.conf /etc/

