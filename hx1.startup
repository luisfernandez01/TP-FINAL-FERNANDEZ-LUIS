# =====================================================
# Host hx1 - LAN de Lx (192.168.2.0/29)
# =====================================================
# IP y conexión
ip addr add 192.168.2.1/29 dev eth2
ip link set eth2 up
# Gateway
ip route add default via 192.168.2.6

# Para que funcione el nameserver
cd shared
cp resolv.conf /etc/

